# EmploySure Environment Configuration
# Copy this file to .env and fill in your API keys

# AI Provider Keys (at least one required)
# Get free key from: https://aistudio.google.com/
GEMINI_API_KEY=

# Get free key from: https://console.groq.com/
GROQ_API_KEY=

# Ollama (optional, for local/offline AI)
# Install from: https://ollama.ai
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Database
DATABASE_URL=sqlite+aiosqlite:///./employsure.db

# Scheduler
RECRAWL_INTERVAL_HOURS=1
VERIFY_LINKS_INTERVAL_HOURS=6

# Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:5173
